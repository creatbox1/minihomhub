# HVAC Cost Guide – Apache Configuration
# Last updated: 2026-04-14

# ──────────────────────────────────────────────
# Enable Rewrite Engine (must be before all RewriteRules)
# ──────────────────────────────────────────────
RewriteEngine On

# ──────────────────────────────────────────────
# Custom Error Pages
# ──────────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html
ErrorDocument 500 /404.html

# ──────────────────────────────────────────────
# Enable Gzip Compression
# ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ──────────────────────────────────────────────
# Browser Caching
# ──────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# ──────────────────────────────────────────────
# Redirect /index.html to /
# ──────────────────────────────────────────────
RewriteCond %{THE_REQUEST} ^[A-Z]+\ /index\.html[?\ ] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ──────────────────────────────────────────────
# Redirect www to non-www
# ──────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+) [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ──────────────────────────────────────────────
# Redirect Old /legal/ URLs to Root (SEO 301)
# ──────────────────────────────────────────────
RewriteRule ^legal/(privacy-policy|terms|disclaimer|contact|cookie-policy|dmca|accessibility|editorial-policy)\.html$ /$1.html [R=301,L]

# ──────────────────────────────────────────────
# Redirect Old Blog URLs to New URLs (SEO 301)
# ──────────────────────────────────────────────

# Old blog posts → new posts (closest match)
RewriteRule ^blog/ac-installation-cost\.html$ /blog/how-much-does-ac-cost-per-month-usa.html [R=301,L]
RewriteRule ^blog/best-thermostat-settings\.html$ /blog/best-temperature-settings-save-cooling-cost.html [R=301,L]
RewriteRule ^blog/cooling-cost-by-state\.html$ /blog/heating-cost-by-state-usa-canada.html [R=301,L]
RewriteRule ^blog/energy-efficient-hvac\.html$ /blog/energy-efficient-hvac-systems-worth-it.html [R=301,L]
RewriteRule ^blog/furnace-installation-cost\.html$ /blog/hvac-installation-cost-usa-canada.html [R=301,L]
RewriteRule ^blog/geothermal-cost-benefit\.html$ /blog/geothermal-heat-pump-costs-savings-2026.html [R=301,L]
RewriteRule ^blog/heat-pump-vs-furnace\.html$ /blog/heat-pump-vs-gas-furnace-2026-costs-savings-comparison.html [R=301,L]
RewriteRule ^blog/how-to-choose-hvac-contractor\.html$ /blog/hvac-installation-cost-usa-canada.html [R=301,L]
RewriteRule ^blog/hvac-cost-guide\.html$ /blog/average-heating-cost-per-month-usa.html [R=301,L]
RewriteRule ^blog/hvac-rebates\.html$ /blog/monthly-energy-saving-tips-us-homeowners.html [R=301,L]
RewriteRule ^blog/when-to-replace-hvac\.html$ /blog/signs-hvac-needs-replacement-guide-2026.html [R=301,L]

# ──────────────────────────────────────────────
# Force HTTPS (if SSL is enabled)
# ──────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ──────────────────────────────────────────────
# Remove trailing slash from non-directory URLs
# ──────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# ──────────────────────────────────────────────
# Security Headers
# ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ──────────────────────────────────────────────
# Block /cgi-bin/ access
# ──────────────────────────────────────────────
RewriteRule ^cgi-bin/ - [R=404,L]

# ──────────────────────────────────────────────
# Prevent Directory Browsing
# ──────────────────────────────────────────────
Options -Indexes
